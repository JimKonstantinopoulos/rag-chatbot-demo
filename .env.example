# --- Supabase (vector store) ---
# Project URL, e.g. https://xxxxxxxx.supabase.co
SUPABASE_URL=
# Service-role key (server-side only — never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=

# --- OpenAI (embeddings only) ---
# Used for text-embedding-3-small (1536 dims). Anthropic has no embeddings API.
OPENAI_API_KEY=

# --- Anthropic (answer generation) ---
ANTHROPIC_API_KEY=
# Cheap + fast default. Bump to claude-sonnet-4-6 or claude-opus-4-8 for richer answers.
ANSWER_MODEL=claude-haiku-4-5
